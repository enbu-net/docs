{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "website",
	"account_id": "cde3f3b62fe75411311327f17ead7604",
	"compatibility_date": "2026-07-17",
	"workers_dev": false,
	"preview_urls": false,
	"routes": [
		{
			"pattern": "enbu.net",
			"zone_name": "enbu.net",
			"custom_domain": true
		}
	],
	"assets": {
		"directory": "./dist",
		"not_found_handling": "404-page"
	},
	"observability": {
		"enabled": false,
		"head_sampling_rate": 1,
		"logs": {
			"enabled": true,
			"head_sampling_rate": 1,
			"persist": true,
			"invocation_logs": true
		},
		"traces": {
			"enabled": false,
			"persist": true,
			"head_sampling_rate": 1
		}
	}
}
